# North Star — environment variables
# Copy to .env.local for local development. DO NOT put AWS credentials here.
# AWS credentials belong only in the Lambda execution role (never the browser,
# never this repo).

# ----- Frontend (Next.js / Vercel) -----
# Public app name shown in the UI and page title.
NEXT_PUBLIC_APP_NAME=North Star

# The AWS API Gateway URL that the Next.js /api/evaluate proxy forwards to.
# Get this from the SAM stack output "EvaluateApiUrl" after deploying infra/.
# Leave blank locally to get a friendly "not configured" message.
EVALUATION_API_URL=

# ----- Backend (Lambda — set as SAM parameters / Lambda env vars) -----
# Bedrock model identifier. Keep configurable; default is Amazon Nova Lite.
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Production origin allowed by CORS (your Vercel URL, e.g. https://north-star.vercel.app).
# Leave blank until Vercel is deployed, then set it and redeploy.
ALLOWED_ORIGIN=

# Local development origin allowed by CORS.
LOCAL_ORIGIN=http://localhost:3000

# Log verbosity: debug | info | warn | error. Only operational metadata is logged.
LOG_LEVEL=info
